<!-- PAGE 2 — EXECUTIVE SUMMARY -->
<!-- ============================================================ -->
<div class="page">
  <div class="page-header">
    <span>§ 01 — Executive Summary</span>
    <span class="right">Renterra BDR · Chris Khoury</span>
  </div>

  <div class="eyebrow">Methodology</div>
  <h1>How I filtered for Renterra-fit accounts.</h1>

  <div class="stat-grid">
    <div class="stat">
      <div class="num">4</div>
      <div class="label">High-fit accounts</div>
    </div>
    <div class="stat">
      <div class="num">90+</div>
      <div class="label">ICP score each</div>
    </div>
    <div class="stat">
      <div class="num">1</div>
      <div class="label">Primary target</div>
    </div>
  </div>

  <div class="two-col">
    <div>
      <h4>Core ICP Signals</h4>
      <ul class="checklist">
