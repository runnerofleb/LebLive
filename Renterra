<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Renterra BDR ICP Briefing — Chris Khoury</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap');

  @page {
    size: Letter;
    margin: 0;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0B1410;
    --bg-2: #0F1A15;
    --panel: #13201A;
    --panel-2: #182821;
    --line: #1F3128;
    --line-2: #2A4338;
    --text: #E6EFE9;
    --text-dim: #9FB4A8;
    --text-faint: #6B8378;
    --accent: #4ADE80;
    --accent-2: #22C55E;
    --accent-soft: rgba(74, 222, 128, 0.12);
    --warn: #FBBF24;
    --danger: #F87171;
  }

  html, body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 10.5pt;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }

  .page {
    width: 8.5in;
    height: 11in;
    padding: 0.55in 0.6in;
    page-break-after: always;
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }
  .page:last-child { page-break-after: auto; }

  /* page header & footer */
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 8pt;
    letter-spacing: 0.12em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 0.35in;
  }
  .page-header .right { color: var(--text-faint); }

  .page-footer {
    position: absolute;
    bottom: 0.35in;
    left: 0.6in;
    right: 0.6in;
    display: flex;
    justify-content: space-between;
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5pt;
    color: var(--text-faint);
    border-top: 1px solid var(--line);
    padding-top: 0.12in;
    letter-spacing: 0.08em;
  }

  /* type system */
  h1, h2, h3, h4 { font-family: 'Fraunces', serif; font-weight: 700; letter-spacing: -0.02em; }
  .display {
    font-family: 'Fraunces', serif;
    font-weight: 900;
    font-size: 64pt;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--text);
  }
  h1 { font-size: 28pt; line-height: 1.05; color: var(--text); }
  h2 { font-size: 18pt; line-height: 1.15; color: var(--text); margin-bottom: 0.08in; }
  h3 { font-size: 13pt; color: var(--text); margin-bottom: 0.06in; }
  h4 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8pt;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.05in;
  }
  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8pt;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.1in;
  }
  p { margin-bottom: 0.08in; }
  .lead { font-size: 11.5pt; color: var(--text-dim); line-height: 1.6; }

  /* ============ COVER ============ */
  .cover {
    background:
      radial-gradient(circle at 80% 15%, rgba(74,222,128,0.10), transparent 45%),
      radial-gradient(circle at 10% 90%, rgba(34,197,94,0.06), transparent 50%),
      var(--bg);
    padding: 0.7in 0.7in 0.4in;
    display: flex;
    flex-direction: column;
  }
  .cover-byline {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9pt;
    letter-spacing: 0.22em;
    color: var(--text-dim);
    text-transform: uppercase;
    text-align: right;
  }
  .cover-eyebrow {
    margin-top: 0.65in;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5pt;
    letter-spacing: 0.24em;
    color: var(--accent);
    text-transform: uppercase;
  }
  .cover-title {
    margin-top: 0.18in;
    font-family: 'Fraunces', serif;
    font-weight: 900;
    font-size: 78pt;
    line-height: 0.92;
    letter-spacing: -0.045em;
    color: var(--text);
  }
  .cover-title em {
    font-style: italic;
    color: var(--accent);
    font-weight: 400;
  }
  .cover-sub {
    margin-top: 0.3in;
    max-width: 5.4in;
    font-size: 13pt;
    line-height: 1.5;
    color: var(--text-dim);
  }
  .cover-tags {
    margin-top: 0.35in;
    display: flex;
    gap: 0.1in;
    flex-wrap: wrap;
  }
  .tag {
    border: 1px solid var(--accent);
    color: var(--accent);
    padding: 0.05in 0.16in;
    border-radius: 100px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 8.5pt;
    letter-spacing: 0.06em;
  }
  .cover-callouts {
    margin-top: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.2in;
  }
  .callout {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0.22in;
  }
  .callout h4 { margin-bottom: 0.08in; }
  .callout .big { font-family: 'Fraunces', serif; font-size: 18pt; font-weight: 700; color: var(--text); line-height: 1.1; margin-bottom: 0.06in; }
  .callout .body { font-size: 9.5pt; color: var(--text-dim); line-height: 1.5; }

  .cover-watermark {
    position: absolute;
    bottom: 0.5in;
    right: -0.15in;
    font-family: 'Fraunces', serif;
    font-size: 180pt;
    font-weight: 900;
    color: rgba(74,222,128,0.04);
    line-height: 0.8;
    letter-spacing: -0.05em;
    pointer-events: none;
  }

  /* ============ GENERAL COMPONENTS ============ */

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.18in;
    margin-top: 0.2in;
    margin-bottom: 0.25in;
  }
  .stat {
    border: 1px solid var(--line);
    background: var(--panel);
    border-radius: 10px;
    padding: 0.18in;
  }
  .stat .num {
    font-family: 'Fraunces', serif;
    font-size: 32pt;
    font-weight: 900;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .stat .label {
    margin-top: 0.06in;
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5pt;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    text-transform: uppercase;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0.22in 0.24in;
    margin-bottom: 0.18in;
  }
  .panel-accent {
    background: linear-gradient(135deg, rgba(74,222,128,0.06), rgba(74,222,128,0.02));
    border: 1px solid var(--line-2);
  }

  ul.checklist {
    list-style: none;
    padding: 0;
  }
  ul.checklist li {
    padding-left: 0.22in;
    position: relative;
    margin-bottom: 0.07in;
    font-size: 10pt;
    line-height: 1.5;
    color: var(--text-dim);
  }
  ul.checklist li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }
  ul.checklist li strong { color: var(--text); }

  /* ============ ICP TABLE ============ */
  table.icp {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin-top: 0.1in;
    font-size: 9.5pt;
  }
  table.icp th, table.icp td {
    text-align: left;
    padding: 0.1in 0.12in;
    border-bottom: 1px solid var(--line);
  }
  table.icp th {
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5pt;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-weight: 600;
    padding-bottom: 0.06in;
  }
  table.icp td.account { font-weight: 600; color: var(--text); }
  table.icp td.score {
    font-family: 'Fraunces', serif;
    font-weight: 700;
    color: var(--accent);
    font-size: 11pt;
  }
  table.icp td.priority { color: var(--text); font-size: 9pt; }
  table.icp td.why { color: var(--text-dim); font-size: 9pt; }

  /* ============ ACCOUNT PAGES ============ */
  .account-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.25in;
    align-items: start;
    padding-bottom: 0.18in;
    margin-bottom: 0.2in;
    border-bottom: 1px solid var(--line);
  }
  .account-num {
    font-family: 'Fraunces', serif;
    font-weight: 900;
    font-size: 56pt;
    line-height: 0.9;
    color: var(--accent);
    letter-spacing: -0.04em;
  }
  .account-title-block .priority-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8pt;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.04in;
  }
  .account-title-block h2 {
    font-size: 22pt;
    margin-bottom: 0.04in;
    line-height: 1.05;
  }
  .account-title-block .desc {
    font-size: 9.5pt;
    color: var(--text-dim);
    line-height: 1.4;
  }
  .score-circle {
    text-align: center;
    border: 2px solid var(--accent);
    background: var(--accent-soft);
    border-radius: 50%;
    width: 0.85in;
    height: 0.85in;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    flex-shrink: 0;
  }
  .score-circle .v {
    font-family: 'Fraunces', serif;
    font-weight: 700;
    font-size: 20pt;
    color: var(--accent);
    line-height: 1;
  }
  .score-circle .l {
    font-family: 'JetBrains Mono', monospace;
    font-size: 6.5pt;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 0.02in;
  }

  .pov-banner {
    background: var(--panel-accent, var(--accent-soft));
    border-left: 3px solid var(--accent);
    padding: 0.14in 0.18in;
    margin-bottom: 0.2in;
    font-size: 10pt;
    color: var(--text);
    line-height: 1.5;
    font-style: italic;
    border-radius: 0 8px 8px 0;
  }
  .pov-banner strong {
    font-style: normal;
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5pt;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 0.04in;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.2in;
    margin-bottom: 0.18in;
  }
  .three-col {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.18in;
  }

  /* snapshot table */
  table.snapshot {
    width: 100%;
    border-collapse: collapse;
    font-size: 9pt;
  }
  table.snapshot td {
    padding: 0.07in 0;
    vertical-align: top;
    border-bottom: 1px dashed var(--line);
  }
  table.snapshot td.label {
    width: 1.1in;
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5pt;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
    padding-right: 0.1in;
    padding-top: 0.09in;
  }
  table.snapshot td.val { color: var(--text-dim); line-height: 1.45; }
  table.snapshot td.val strong { color: var(--text); font-weight: 600; }
  table.snapshot tr:last-child td { border-bottom: none; }

  /* discovery list */
  ul.discovery {
    list-style: none;
    padding: 0;
    counter-reset: dq;
  }
  ul.discovery li {
    counter-increment: dq;
    padding-left: 0.3in;
    position: relative;
    margin-bottom: 0.09in;
    font-size: 9.5pt;
    line-height: 1.45;
    color: var(--text-dim);
    font-style: italic;
  }
  ul.discovery li::before {
    content: "Q" counter(dq);
    position: absolute;
    left: 0;
    top: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5pt;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.04em;
    font-style: normal;
  }

  /* value map chips */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.06in;
    margin-top: 0.05in;
  }
  .chip {
    background: var(--accent-soft);
    border: 1px solid rgba(74,222,128,0.3);
    color: var(--text);
    padding: 0.04in 0.12in;
    border-radius: 6px;
    font-size: 8.5pt;
    line-height: 1.3;
  }

  /* opening wedge box */
  .wedge {
    background: var(--bg-2);
    border: 1px dashed var(--accent);
    border-radius: 10px;
    padding: 0.18in 0.2in;
    margin-top: 0.15in;
    position: relative;
  }
  .wedge .lab {
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5pt;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.06in;
  }
  .wedge .quote {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 11pt;
    line-height: 1.5;
    color: var(--text);
  }
  .wedge .quote::before {
    content: "\201C";
    font-size: 22pt;
    color: var(--accent);
    line-height: 0;
    vertical-align: -0.06in;
    margin-right: 0.04in;
  }
  .wedge .quote::after {
    content: "\201D";
    font-size: 22pt;
    color: var(--accent);
    line-height: 0;
    vertical-align: -0.06in;
    margin-left: 0.04in;
  }

  /* ============ COMPETITOR TABLE ============ */
  table.competitors {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 9pt;
    margin-top: 0.1in;
  }
  table.competitors th, table.competitors td {
    text-align: left;
    padding: 0.09in 0.12in;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
  }
  table.competitors th {
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5pt;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-weight: 600;
  }
  table.competitors td.what { font-weight: 600; color: var(--text); }
  table.competitors td.tier { color: var(--text-dim); }
  table.competitors td.wedge-col { color: var(--accent); font-style: italic; font-size: 8.5pt; }

  /* ============ OBJECTIONS ============ */
  .obj {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 0.15in 0.18in;
    margin-bottom: 0.12in;
    page-break-inside: avoid;
  }
  .obj .question {
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5pt;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--danger);
    margin-bottom: 0.05in;
  }
  .obj .said {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 10.5pt;
    color: var(--text);
    margin-bottom: 0.08in;
    line-height: 1.4;
  }
  .obj .response-lab {
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5pt;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.05in;
  }
  .obj .response {
    font-size: 9.5pt;
    color: var(--text-dim);
    line-height: 1.5;
  }

  /* ============ EXECUTION PLAN ============ */
  .flow-step {
    display: grid;
    grid-template-columns: 0.4in 1fr;
    gap: 0.1in;
    margin-bottom: 0.12in;
    align-items: start;
  }
  .flow-num {
    font-family: 'Fraunces', serif;
    font-weight: 900;
    font-size: 20pt;
    color: var(--accent);
    line-height: 1;
  }
  .flow-content h4 {
    color: var(--text);
    text-transform: none;
    letter-spacing: 0;
    font-family: 'Fraunces', serif;
    font-size: 11pt;
    margin-bottom: 0.03in;
  }
  .flow-content p {
    font-size: 9.5pt;
    color: var(--text-dim);
    line-height: 1.45;
    margin: 0;
  }

  /* ============ MAPPING TABLE ============ */
  table.map {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 9pt;
  }
  table.map th, table.map td {
    padding: 0.09in 0.12in;
    text-align: left;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
  }
  table.map th {
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5pt;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  table.map td.trigger {
    font-style: italic;
    color: var(--text);
    width: 48%;
  }
  table.map td.anchor {
    color: var(--accent);
    font-weight: 500;
  }

  /* ============ DO/DON'T ============ */
  .do-dont {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.18in;
    margin-bottom: 0.18in;
  }
  .do-dont .col {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 0.18in 0.2in;
  }
  .do-dont h4 { margin-bottom: 0.1in; }
  .do-dont .col.do h4 { color: var(--accent); }
  .do-dont .col.dont h4 { color: var(--danger); }
  .do-dont ul { list-style: none; padding: 0; }
  .do-dont li {
    padding-left: 0.2in;
    position: relative;
    margin-bottom: 0.07in;
    font-size: 9.5pt;
    line-height: 1.45;
    color: var(--text-dim);
  }
  .do-dont .col.do li::before {
    content: "+";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .do-dont .col.dont li::before {
    content: "×";
    position: absolute;
    left: 0;
    color: var(--danger);
    font-weight: 700;
  }

  /* misc */
  .divider {
    border-top: 1px solid var(--line);
    margin: 0.2in 0;
  }
  .small-mono {
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5pt;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .sources-list {
    list-style: none;
    padding: 0;
    font-size: 9pt;
    color: var(--text-dim);
    line-height: 1.55;
  }
  .sources-list li {
    padding: 0.07in 0;
    border-bottom: 1px dashed var(--line);
  }
  .sources-list li strong { color: var(--text); }
</style>
</head>
<body>

